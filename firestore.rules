rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isPrimaryAdmin() {
      return signedIn() && request.auth.token.email.lower() == 'khaitri15@gmail.com';
    }

    function hasAccessDocument() {
      return signedIn()
        && exists(/databases/$(database)/documents/access/$(request.auth.token.email.lower()))
        && get(/databases/$(database)/documents/access/$(request.auth.token.email.lower())).data.active == true;
    }

    function isAllowed() {
      return isPrimaryAdmin() || hasAccessDocument();
    }

    function isAdmin() {
      return isPrimaryAdmin()
        || (hasAccessDocument()
          && get(/databases/$(database)/documents/access/$(request.auth.token.email.lower())).data.role == 'admin');
    }

    function canEdit() {
      return isPrimaryAdmin()
        || (hasAccessDocument()
          && get(/databases/$(database)/documents/access/$(request.auth.token.email.lower())).data.role in ['admin', 'editor']);
    }

    match /access/{email} {
      allow get: if isAdmin() || (signedIn() && email == request.auth.token.email.lower());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /apartments/{apartmentId} {
      allow read: if isAllowed();
      allow create, update, delete: if canEdit();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
